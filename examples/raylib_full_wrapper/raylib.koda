    SHADER_LOC_MAP_NORMAL = 17;
const ShaderLocationIndex_// Shader location: sampler2d texture: normal
    SHADER_LOC_MAP_ROUGHNESS = 18;
const ShaderLocationIndex_// Shader location: sampler2d texture: roughness
    SHADER_LOC_MAP_OCCLUSION = 19;
const ShaderLocationIndex_// Shader location: sampler2d texture: occlusion
    SHADER_LOC_MAP_EMISSION = 20;
const ShaderLocationIndex_// Shader location: sampler2d texture: emission
    SHADER_LOC_MAP_HEIGHT = 21;
const ShaderLocationIndex_// Shader location: sampler2d texture: heightmap
    SHADER_LOC_MAP_CUBEMAP = 22;
const ShaderLocationIndex_// Shader location: samplerCube texture: cubemap
    SHADER_LOC_MAP_IRRADIANCE = 23;
const ShaderLocationIndex_// Shader location: samplerCube texture: irradiance
    SHADER_LOC_MAP_PREFILTER = 24;
const ShaderLocationIndex_// Shader location: samplerCube texture: prefilter
    SHADER_LOC_MAP_BRDF = 25;
const ShaderLocationIndex_// Shader location: sampler2d texture: brdf
    SHADER_LOC_VERTEX_BONEIDS = 26;
const ShaderLocationIndex_// Shader location: vertex attribute: bone indices
    SHADER_LOC_VERTEX_BONEWEIGHTS = 27;
const ShaderLocationIndex_// Shader location: vertex attribute: bone weights
    SHADER_LOC_MATRIX_BONETRANSFORMS = 28;
const ShaderLocationIndex_// Shader location: matrix attribute: bone transforms (animation)
    SHADER_LOC_VERTEX_INSTANCETRANSFORM // Shader location: vertex attribute: instance transforms = 29;

