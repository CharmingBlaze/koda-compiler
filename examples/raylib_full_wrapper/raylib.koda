    SHADER_ATTRIB_VEC4              // Shader attribute type: vec4 (4 float) = 3;

// Enum: PixelFormat
const PixelFormat_PIXELFORMAT_UNCOMPRESSED_GRAYSCALE = 1;
const PixelFormat_// 8 bit per pixel (no alpha)
    PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA = 1;
