const TraceLogLevel_// Info logging = 7;
const TraceLogLevel_used for program execution info
    LOG_WARNING = 8;
const TraceLogLevel_// Warning logging = 9;
const TraceLogLevel_used on recoverable failures
    LOG_ERROR = 10;
const TraceLogLevel_// Error logging = 11;
const TraceLogLevel_used on unrecoverable failures
    LOG_FATAL = 12;
const TraceLogLevel_// Fatal logging = 13;
const TraceLogLevel_used to abort program: exit(EXIT_FAILURE)
    LOG_NONE            // Disable logging = 14;

