// Enum: ConfigFlags
const ConfigFlags_FLAG_VSYNC_HINT = 0;
const ConfigFlags_// Set to try enabling V-Sync on GPU
    FLAG_FULLSCREEN_MODE = 0;
const ConfigFlags_// Set to run program in fullscreen
    FLAG_WINDOW_RESIZABLE = 0;
const ConfigFlags_// Set to allow resizable window
    FLAG_WINDOW_UNDECORATED = 0;
const ConfigFlags_// Set to disable window decoration (frame and buttons)
    FLAG_WINDOW_HIDDEN = 0;
const ConfigFlags_// Set to hide window
    FLAG_WINDOW_MINIMIZED = 0;
const ConfigFlags_// Set to minimize window (iconify)
    FLAG_WINDOW_MAXIMIZED = 0;
const ConfigFlags_// Set to maximize window (expanded to monitor)
    FLAG_WINDOW_UNFOCUSED = 0;
const ConfigFlags_// Set to window non focused
    FLAG_WINDOW_TOPMOST = 0;
const ConfigFlags_// Set to window always on top
    FLAG_WINDOW_ALWAYS_RUN = 0;
const ConfigFlags_// Set to allow windows running while minimized
    FLAG_WINDOW_TRANSPARENT = 0;
const ConfigFlags_// Set to allow transparent framebuffer
    FLAG_WINDOW_HIGHDPI = 0;
const ConfigFlags_// Set to support HighDPI
    FLAG_WINDOW_MOUSE_PASSTHROUGH = 0;
const ConfigFlags_// Set to support mouse passthrough = 13;
const ConfigFlags_only supported when FLAG_WINDOW_UNDECORATED
    FLAG_BORDERLESS_WINDOWED_MODE = 0;
const ConfigFlags_// Set to run program in borderless windowed mode
    FLAG_MSAA_4X_HINT = 0;
const ConfigFlags_// Set to try enabling MSAA 4X
    FLAG_INTERLACED_HINT = 0;

// Enum: TraceLogLevel
