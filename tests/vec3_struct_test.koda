#include "../stdlib/vec3.koda"

func main() {
    let z = zero();
    assert(z.x == 0.0, "zero x");
    assert(z.y == 0.0, "zero y");
    assert(z.z == 0.0, "zero z");

    let a = create(1, 2, 3);
    let b = create(4, 5, 6);
    let c = add(a, b);
    assert(c.x == 5.0 && c.y == 7.0 && c.z == 9.0, "add");

    let v = Vec3 { x: 3.0, y: 0.0, z: 4.0 };
    assert(dot(v, v) == 25.0, "dot typed Vec3");
    assert(length(v) == 5.0, "length typed Vec3 through nested dot");
    print("PASS vec3_struct");
}
