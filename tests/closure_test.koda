print("--- Testing Basic Anonymous Function ---");

let add = func(a, b) {
    return a + b;
};

print(add(10, 20));
print("--- Testing Closure (makeCounter) ---");

func makecounter() {
    let count = 0;
    return func() {
        count = count + 1;
        return count;
    };
}

let c1 = makecounter();

print(c1());
print(c1());

let c2 = makecounter();

print(c2());
print(c1());
print("--- Testing Nested Closures ---");

func multiplier(factor) {
    return func(x) {
        return func(y) {
            return x * y * factor;
        };
    };
}

let double = multiplier(2)(10);

print(double(5));
print("Closure tests complete!");
