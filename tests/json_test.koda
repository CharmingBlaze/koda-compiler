let json = import "@json";

let data = { name: "Koda", version: 1.2, features: ["Native", "Fast", "Optimized"], active: true, meta: null };

print("Original data:");
print(data);
print("Stringified:");

let s = json.stringify(data);

print(s);
print("Parsed back:");

let p = json.parse(s);

print(p);

if (p.name == "Koda" && p.version == 1.2 && p.features[0] == "Native") {
    print("JSON Parse/Stringify successful!");
} else {
    print("JSON failure.");
}
