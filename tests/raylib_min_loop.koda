#include "../wrappers/raylib_shim/raylib.koda"

let black = colors.black;

let white = colors.white;

initwindow(640, 360, "Koda Raylib Min Loop");
settargetfps(60);

while (!windowshouldclose()) {
    begindrawing();
    clearbackground(black);
    drawtext("Koda min loop running", 140, 160, 24, white);
    enddrawing();
}

closewindow();
