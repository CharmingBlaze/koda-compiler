print("Length test:");
print(len("Hello"));
print(len([1, 2, 3, 4]));
print(len({ a: 1, b: 2 }));
print("Type test:");
print(type(10));
print(type("str"));
print(type(true));
print(type([]));
print(type({}));
print("Clock test:");

let start = clock();

let i = 0;

while (i < 1000000) {
    i = i + 1;
}

let end = clock();

print("Time taken for 100k increments:");
print(end - start);
