func allocating() {
    return [1, 2, 3];
}

let i = 0;

let sink = [];

while (i < 800) {
    let x = [{ a: i }, [i, i + 1, i + 2], allocating(), { b: [i, i * 2, i * 3] }];
    let valid = len(x) > 0 && len(x) < 20;
    if (valid == false) {
        print("FAIL");
    }
    sink = [sink, x];
    if (len(sink) > 16) {
        sink = [];
    }
    i = i + 1;
}

print("PASS");
