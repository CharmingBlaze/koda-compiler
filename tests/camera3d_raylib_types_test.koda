use raylib;

func main() {
    let camera = Camera3D {
        position: vec3(1.0, 2.0, 3.0),
        target: vec3(0.0, 0.0, 0.0),
        up: vec3(0.0, 1.0, 0.0),
        fovy: 45.0,
        projection: CAMERA_PERSPECTIVE
    };
    assert(camera.fovy == 45.0, "camera fovy");
    assert(camera.position.x == 1.0, "camera position x");
    assert(RAYWHITE.r == 245, "RAYWHITE r");
    assert(colors.rebeccaPurple == rgb(102, 51, 153), "rebeccaPurple");
    print("PASS camera3d_raylib_types");
}
