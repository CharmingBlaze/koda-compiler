let g0 = { k: 0 };

let g1 = { k: 1 };

let g2 = { k: 2 };

let g3 = { k: 3 };

let g4 = { k: 4 };

let g5 = { k: 5 };

let g6 = { k: 6 };

let g7 = { k: 7 };

let g8 = { k: 8 };

let g9 = { k: 9 };

let roots = [g0, g1, g2, g3, g4, g5, g6, g7, g8, g9];

let i = 0;

while (i < 1200) {
    let obj = { idx: i, payload: [i, i + 1, i + 2, { deep: [i * 2, i * 3] }], keep: roots };
    roots = [roots, obj];
    if (len(roots) > 24) {
        roots = [];
    }
    i = i + 1;
}

print("globals stress ok");
