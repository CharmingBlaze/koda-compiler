let arr = [10, 20, 30];

print("Original array:");
print(arr);
print("Index 1:");
print(arr[1]);
arr[1] = 99;
print("Modified array:");
print(arr);

let user = { name: "Alice", age: 25 };

print("User name:");
print(user.name);
user.age = 26;
user.city = "London";
print("Modified user:");
print(user);
print("Access by index:");
print(user["name"]);
