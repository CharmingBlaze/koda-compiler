print("--- Time Utils ---");
print("Time:", time());
print("Timestamp:", timestamp());
print("DeltaTime (initial):", deltatime());
sleep(10);
print("DeltaTime (after sleep):", deltatime());
print("\n--- Random Utils ---");
randomseed(42);
print("Random (0..1):", random());
print("Random (0..10):", random(10));
print("Random (5..10):", random(5, 10));
print("RandomInt (0..10):", randomint(10));
print("RandomInt (5..10):", randomint(5, 10));

let choices = ["A", "B", "C"];

print("RandomChoice:", randomchoice(choices));
print("\n--- Math Utils ---");
print("Min (1, 2, 3, -1):", min(1, 2, 3, -1));
print("Max (1, 2, 3, -1):", max(1, 2, 3, -1));
print("Clamp (50, 0, 100):", clamp(50, 0, 100));
print("Clamp (-10, 0, 100):", clamp(-10, 0, 100));
print("Clamp (150, 0, 100):", clamp(150, 0, 100));
print("Lerp (0, 100, 0.5):", lerp(0, 100, 0.5));
print("Smoothstep (0, 100, 50):", smoothstep(0, 100, 50));
print("Map (5, 0, 10, 0, 100):", map(5, 0, 10, 0, 100));
print("Sign (-5):", sign(-5));
print("Sign (0):", sign(0));
print("Sign (5):", sign(5));
print("Distance (0,0, 3,4):", distance(0, 0, 3, 4));
print("DistanceSq (0,0, 3,4):", distancesq(0, 0, 3, 4));
print("AngleBetween (0,0, 1,1):", anglebetween(0, 0, 1, 1));

let n = normalize(3, 4);

print("Normalize (3, 4):", n.x, n.y);
print("\n--- Timers (Async) ---");
settimeout(func() {
    print("Timeout 1s fired!");
}, 1000);
print("Script finished, waiting for timers...");
