let x = 42;

let name = "Jesse";

let empty;

let numbers = [1, 2, 3];

let person = { name: "Alice", age: 30 };

x += 5;
x = x + 1;
print("Operators:", x == 48);

if (x > 40) {
    print("If: OK");
}

switch (name) {
    case "Jesse":
        print("Switch: OK");
        break;
}

print("Iteration:");

for (let item of numbers) {
    print("-", item);
}

let letters = ["A", "B"];

let ii = 0;

while (ii < len(letters)) {
    print(ii, ":", letters[ii]);
    ii = ii + 1;
}

for (let kk of ["name", "age"]) {
    print(kk, "=", person[kk]);
}

for (let c of ["h", "i"]) {
    print("char:", c);
}

func makecounter() {
    let count = 0;
    return func() {
        count += 1;
        return count;
    };
}

let counter = makecounter();

print("Counter:", counter(), counter());

let player = { hp: 100, damage: func(amt) {
    player.hp = player.hp - amt;
} };

player.damage(20);
print("Player HP:", player.hp);

let arr = [10, 20];

arr.push(30);
print("Length:", len(arr));
print("Pop:", arr.pop());
print("Type:", type(arr), "Len:", len("hello"));
print("Reference Test Complete");
