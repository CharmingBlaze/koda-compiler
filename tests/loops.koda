print("While loop:");

let i = 0;

while (i < 5) {
    print(i);
    i = i + 1;
}

print("For-style loop (while):");

let j = 0;

while (j < 3) {
    print(j);
    j = j + 1;
}

print("Break test:");

let k = 0;

while (k < 10) {
    if (k == 3) {
        break;
    }
    print(k);
    k = k + 1;
}

print("Continue test:");

let m = 0;

while (m < 5) {
    if (m == 2) {
        m = m + 1;
        continue;
    }
    print(m);
    m = m + 1;
}
