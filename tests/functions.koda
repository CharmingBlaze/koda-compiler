func fib(n) {
    if (n <= 1)
        return n;
    return fib(n - 1) + fib(n - 2);
}

print("Fibonacci(10):", fib(10));

func makecounter() {
    let count = 0;
    return func() {
        count = count + 1;
        return count;
    };
}

let counter = makecounter();

print("Count 1:", counter());
print("Count 2:", counter());
print("Count 3:", counter());
