#include "../stdlib/vec3.koda"

func main() {
    let u = create(1, 0, 0);
    let v = create(0, 1, 0);
    let s = add(u, v);
    assert(s.x == 1, "add.x");
    assert(s.y == 1, "add.y");
    assert(s.z == 0, "add.z");
    let c = cross(u, v);
    assert(c.x == 0, "cross.x");
    assert(c.y == 0, "cross.y");
    assert(c.z == 1, "cross.z");
    assert(length(create(2, 0, 0)) == 2.0, "length");
    let mid = lerp(create(0, 0, 0), create(10, 0, 0), 0.5);
    assert(mid.x == 5.0, "lerp.x");
    assert(mid.y == 0.0, "lerp.y");
    assert(mid.z == 0.0, "lerp.z");
    print("PASS vec3");
}
