func main() {
    let totalfor = 0;
    for (let i = 0; i < 5; i += 1) {
        if (i == 3) {
            continue;
        }
        totalfor += i;
    }
    print("for", totalfor);
    let totalwhile = 0;
    let j = 0;
    while (j < 5) {
        if (j == 3) {
            j += 1;
            continue;
        }
        totalwhile += j;
        j += 1;
    }
    print("while", totalwhile);
}
