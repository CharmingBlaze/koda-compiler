let pos = vec3(0, 1, 8);
let velocity = vec3(1, 0, 0);
let dt = 0.016;
let speed = 5.0;

pos = pos + velocity * speed * dt;
assert(pos.x > 0, "vec3 move x");
assert(pos.y == 1, "vec3 move y");
assert(pos.z == 8, "vec3 move z");

pos += vec3(0, 0.5, 0);
assert(pos.y == 1.5, "vec3 +=");

let v2 = vec2(3, 4);
assert(v2.x == 3 && v2.y == 4, "vec2");

let scaled = v2 * 2;
assert(scaled.x == 6 && scaled.y == 8, "vec2 * scalar");

let r = rect(10, 20, 100, 50);
assert(r.w == 100 && r.h == 50, "rect");

let b = box(vec3(0, 1, 0), vec3(2, 3, 4));
assert(b.center.y == 1, "box center");
assert(b.size.z == 4, "box size");

let c = color(255, 128, 0);
assert(c.r == 255 && c.g == 128 && c.b == 0, "color rgb");
assert(c.packed == rgb(255, 128, 0), "color.packed");

print("PASS game types");
